{
  "name": "photobooth-monorepo",
  "version": "1.3.0",
  "private": true,
  "description": "PhotoBooth Full-Stack Monorepo",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build": "npm run build --workspace=frontend",
    "commit": "node sync.js",
    "clean": "rmdir /s /q node_modules frontend\\node_modules backend\\node_modules"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
